{
  "name": "assetpaste",
  "version": "0.1.0",
  "description": "Paste images into Webflow Assets from your clipboard, files, or drag and drop.",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kmbashar/AssetPaste.git"
  },
  "scripts": {
    "dev": "npm run build && webflow extension serve --skip-update-check",
    "local": "vite --host 0.0.0.0",
    "build": "vite build",
