    "check": "npm run build",
    "preview": "vite --host 0.0.0.0"
  },
  "devDependencies": {
    "@webflow/webflow-cli": "^1.23.0"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.14"
  }
}
